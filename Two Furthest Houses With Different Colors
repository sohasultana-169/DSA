class Solution {
public:
    int maxDistance(vector<int>& colors) {
        int n = colors.size();

        for (int i = 0; i < n - 1; i++) {
            if (colors[0] != colors[n - 1 - i] || colors[n - 1] != colors[i]) {
                return n - i - 1;
            }
        }

        return 0;
    }
};
